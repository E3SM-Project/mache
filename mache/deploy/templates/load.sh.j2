#!/bin/bash

# Auto-generated by `mache deploy run`

export MACHE_DEPLOY_TARGET_SOFTWARE={{ software | tojson }}
export MACHE_DEPLOY_TARGET_VERSION={{ software_version | tojson }}
{% if runtime_version_cmd_sh != "''" -%}
export MACHE_DEPLOY_RUNTIME_VERSION_CMD={{ runtime_version_cmd_sh }}
{% endif -%}
{% if toolchain_compiler -%}
export MACHE_DEPLOY_TOOLCHAIN_COMPILER={{ toolchain_compiler | tojson }}
{% endif -%}
{% if toolchain_mpi -%}
export MACHE_DEPLOY_TOOLCHAIN_MPI={{ toolchain_mpi | tojson }}
{% endif -%}
{% if spack_library_view -%}
export MACHE_DEPLOY_SPACK_LIBRARY_VIEW={{ spack_library_view | tojson }}
{% endif -%}
export MACHE_DEPLOY_COMPUTE_PIXI_EXE={{ compute_pixi_exe | tojson }}
export MACHE_DEPLOY_COMPUTE_PIXI_PREFIX={{ prefix | tojson }}
export MACHE_DEPLOY_COMPUTE_PIXI_TOML={{ pixi_toml | tojson }}
export MACHE_DEPLOY_COMPUTE_PIXI_MPI={{ compute_pixi_mpi | tojson }}
export MACHE_DEPLOY_COMPUTE_TARGET_LOAD_SNIPPET={{ compute_target_load_snippet | tojson }}
{% if login_pixi_toml -%}
export MACHE_DEPLOY_LOGIN_PIXI_EXE={{ login_pixi_exe | tojson }}
export MACHE_DEPLOY_LOGIN_PIXI_PREFIX={{ login_prefix | tojson }}
export MACHE_DEPLOY_LOGIN_PIXI_TOML={{ login_pixi_toml | tojson }}
export MACHE_DEPLOY_LOGIN_PIXI_MPI={{ login_pixi_mpi | tojson }}
export MACHE_DEPLOY_LOGIN_TARGET_LOAD_SNIPPET={{ login_target_load_snippet | tojson }}
{% endif -%}
{% if machine -%}
export {{ software_upper }}_MACHINE={{ machine | tojson }}
{% endif -%}
{% if branch_path -%}
export {{ software_upper }}_BRANCH={{ branch_path | tojson }}
{% endif -%}
export {{ software_upper }}_VERSION={{ software_version | tojson }}
{% if toolchain_compiler -%}
export {{ software_upper }}_COMPILER={{ toolchain_compiler | tojson }}
{% endif -%}
{% if toolchain_mpi -%}
export {{ software_upper }}_MPI={{ toolchain_mpi | tojson }}
{% endif -%}
export {{ software_upper }}_LOAD_SCRIPT={{ load_script | tojson }}

# Activate the pixi environment in the *current* shell.
#
# NOTE: This script is intentionally **source-only**.
# Use:
#   source load_*.sh
#
# If you want a new shell, you can run `bash` after sourcing.
if [[ -z "${BASH_VERSION:-}" ]]; then
  echo "ERROR: run this script under bash (do not source it from another shell)." >&2
  return 1
fi

# Verify this script is sourced.
if ! (return 0 2>/dev/null); then
  echo "ERROR: this script must be sourced: 'source load_*.sh'" >&2
  exit 1
fi

{% if login_pixi_toml -%}
_mache_deploy_is_compute_node() {
  [[ -n "${SLURM_JOB_ID:-}" || -n "${COBALT_JOBID:-}" || -n "${PBS_JOBID:-}" ]]
}

MACHE_DEPLOY_ACTIVE_ENV_KIND="compute"
MACHE_DEPLOY_ACTIVE_PIXI_EXE="${MACHE_DEPLOY_COMPUTE_PIXI_EXE}"
MACHE_DEPLOY_ACTIVE_PIXI_PREFIX="${MACHE_DEPLOY_COMPUTE_PIXI_PREFIX}"
MACHE_DEPLOY_ACTIVE_PIXI_TOML="${MACHE_DEPLOY_COMPUTE_PIXI_TOML}"
MACHE_DEPLOY_ACTIVE_PIXI_MPI="${MACHE_DEPLOY_COMPUTE_PIXI_MPI}"
MACHE_DEPLOY_ACTIVE_TARGET_LOAD_SNIPPET="${MACHE_DEPLOY_COMPUTE_TARGET_LOAD_SNIPPET}"

if [[ -n "${MACHE_DEPLOY_LOGIN_PIXI_TOML:-}" ]] && ! _mache_deploy_is_compute_node; then
  MACHE_DEPLOY_ACTIVE_ENV_KIND="login"
  MACHE_DEPLOY_ACTIVE_PIXI_EXE="${MACHE_DEPLOY_LOGIN_PIXI_EXE}"
  MACHE_DEPLOY_ACTIVE_PIXI_PREFIX="${MACHE_DEPLOY_LOGIN_PIXI_PREFIX}"
  MACHE_DEPLOY_ACTIVE_PIXI_TOML="${MACHE_DEPLOY_LOGIN_PIXI_TOML}"
  MACHE_DEPLOY_ACTIVE_PIXI_MPI="${MACHE_DEPLOY_LOGIN_PIXI_MPI}"
  MACHE_DEPLOY_ACTIVE_TARGET_LOAD_SNIPPET="${MACHE_DEPLOY_LOGIN_TARGET_LOAD_SNIPPET}"
fi
{% else -%}
MACHE_DEPLOY_ACTIVE_ENV_KIND="compute"
MACHE_DEPLOY_ACTIVE_PIXI_EXE="${MACHE_DEPLOY_COMPUTE_PIXI_EXE}"
MACHE_DEPLOY_ACTIVE_PIXI_PREFIX="${MACHE_DEPLOY_COMPUTE_PIXI_PREFIX}"
MACHE_DEPLOY_ACTIVE_PIXI_TOML="${MACHE_DEPLOY_COMPUTE_PIXI_TOML}"
MACHE_DEPLOY_ACTIVE_PIXI_MPI="${MACHE_DEPLOY_COMPUTE_PIXI_MPI}"
MACHE_DEPLOY_ACTIVE_TARGET_LOAD_SNIPPET="${MACHE_DEPLOY_COMPUTE_TARGET_LOAD_SNIPPET}"
{% endif -%}

if [[ -z "${MACHE_DEPLOY_ACTIVE_PIXI_EXE:-}" ]]; then
  if [[ -n "${PIXI:-}" ]]; then
    MACHE_DEPLOY_ACTIVE_PIXI_EXE="${PIXI}"
  elif command -v pixi >/dev/null 2>&1; then
    MACHE_DEPLOY_ACTIVE_PIXI_EXE="$(command -v pixi)"
  else
    echo "ERROR: pixi executable not found." >&2
    echo "  Set PIXI to a pixi executable path or ensure 'pixi' is on PATH." >&2
    return 1
  fi
fi

export MACHE_DEPLOY_ACTIVE_ENV_KIND
export MACHE_DEPLOY_ACTIVE_PIXI_EXE
export MACHE_DEPLOY_ACTIVE_PIXI_PREFIX
export MACHE_DEPLOY_ACTIVE_PIXI_TOML
export MACHE_DEPLOY_ACTIVE_PIXI_MPI
export MACHE_DEPLOY_ACTIVE_TARGET_LOAD_SNIPPET
export PIXI="${MACHE_DEPLOY_ACTIVE_PIXI_EXE}"
export PIXI_PREFIX="${MACHE_DEPLOY_ACTIVE_PIXI_PREFIX}"
export PIXI_TOML="${MACHE_DEPLOY_ACTIVE_PIXI_TOML}"
export MACHE_DEPLOY_TARGET_LOAD_SNIPPET="${MACHE_DEPLOY_ACTIVE_TARGET_LOAD_SNIPPET}"
export {{ software_upper }}_PIXI_MPI="${MACHE_DEPLOY_ACTIVE_PIXI_MPI}"

# Optional: verify the deployed software version matches the runtime version.
#
# The probe command (if set) is executed in the target pixi environment via
# `pixi run -m <pixi.toml> ...` *before* activation, so a mismatch can abort
# cleanly without changing the current shell.
if [[ -n "${MACHE_DEPLOY_RUNTIME_VERSION_CMD:-}" ]]; then
  echo "verifying deployed ${MACHE_DEPLOY_TARGET_SOFTWARE} version..."
  expected_version="${MACHE_DEPLOY_TARGET_VERSION:-}"
  if [[ -z "${expected_version}" ]]; then
    echo "ERROR: expected version is empty (MACHE_DEPLOY_TARGET_VERSION)." >&2
    return 1
  fi

  # Use a non-login shell so pixi-provided PATH/env are not reset by site profiles.
  probe_output="$(
    env -u PIXI_PROJECT_MANIFEST -u PIXI_PROJECT_ROOT \
      -u PIXI_ENVIRONMENT_NAME -u PIXI_IN_SHELL \
      "${PIXI}" run -m "${MACHE_DEPLOY_ACTIVE_PIXI_TOML}" -- \
      bash -c "${MACHE_DEPLOY_RUNTIME_VERSION_CMD}" 2>&1
  )"
  status=$?

  runtime_version="$(printf '%s\n' "${probe_output}" | head -n 1 | tr -d '\r' | xargs)"

  if [[ ${status} -ne 0 ]]; then
    echo "ERROR: runtime version probe failed (exit ${status})." >&2
    echo "  Probe: ${MACHE_DEPLOY_RUNTIME_VERSION_CMD}" >&2
    if [[ -n "${probe_output}" ]]; then
      echo "  Output: ${probe_output}" >&2
    fi
    return 1
  fi

  if [[ -z "${runtime_version}" ]]; then
    echo "ERROR: runtime version probe produced empty output." >&2
    echo "  Probe: ${MACHE_DEPLOY_RUNTIME_VERSION_CMD}" >&2
    if [[ -n "${probe_output}" ]]; then
      echo "  Output: ${probe_output}" >&2
    fi
    return 1
  fi

  if [[ "${runtime_version}" != "${expected_version}" ]]; then
    echo "ERROR: version mismatch for ${MACHE_DEPLOY_TARGET_SOFTWARE}." >&2
    echo "  Deployed: ${expected_version}" >&2
    echo "  Runtime:  ${runtime_version}" >&2
    return 1
  fi
  echo "  Verified version ${runtime_version}."
fi

echo "loading ${MACHE_DEPLOY_ACTIVE_ENV_KIND} pixi env..."
# Use `shell-hook` (not `pixi run`) so activation applies to this shell.
eval "$(env -u PIXI_PROJECT_MANIFEST -u PIXI_PROJECT_ROOT \
  -u PIXI_ENVIRONMENT_NAME -u PIXI_IN_SHELL \
  "${PIXI}" shell-hook -s bash -m "${MACHE_DEPLOY_ACTIVE_PIXI_TOML}")"
echo "   pixi env loaded."

# Spack activation (optional)
{% if spack_activation -%}
if [[ "${MACHE_DEPLOY_ACTIVE_ENV_KIND}" == "compute" ]]; then
echo "activating spack env..."
{{ spack_activation }}
echo "   spack env activated."
fi
{% endif -%}

# Target software load snippet (optional)
if [[ -n "${MACHE_DEPLOY_TARGET_LOAD_SNIPPET:-}" \
      && -f "${MACHE_DEPLOY_TARGET_LOAD_SNIPPET}" ]]; then
  echo "loading ${MACHE_DEPLOY_TARGET_SOFTWARE} environment variables..."
  # shellcheck source=/dev/null
  source "${MACHE_DEPLOY_TARGET_LOAD_SNIPPET}"
  echo "   ${MACHE_DEPLOY_TARGET_SOFTWARE} environment variables loaded."
fi
