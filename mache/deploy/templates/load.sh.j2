#!/bin/bash
set -e

# Auto-generated by `mache deploy run`

export MACHE_DEPLOY_TARGET_SOFTWARE={{ software | tojson }}
export {{ software_upper }}_PIXI_PREFIX={{ prefix | tojson }}
export {{ software_upper }}_PIXI_TOML={{ pixi_toml | tojson }}
export {{ software_upper }}_BRANCH={{ source_path | tojson }}
export {{ software_upper }}_VERSION={{ software_version | tojson }}

# Start an interactive shell in this pixi project.
# Note: env vars above are inherited into the pixi shell.
#
# We use `pixi run bash -lc ...` rather than `pixi shell` so we can add
# additional activation steps later (e.g. Spack) before handing control to the
# user.
exec env -u PIXI_PROJECT_MANIFEST -u PIXI_PROJECT_ROOT \
  {{ pixi_exe | tojson }} run -m {{ pixi_toml | tojson }} bash -lc 'exec bash -i'
