schema_version: 1

context:
  version: "[[ jigsaw_version ]]"

package:
  name: jigsawpy
  version: ${{ version }}

source:
  path: [[ jigsaw_python_src_dir ]]

build:
  number: 0
  skip: win

requirements:
  build:
    - ${{ compiler('c') }}
    - ${{ stdlib('c') }}
    - ${{ compiler('cxx') }}
    - cmake
    - make
    - pkg-config
    - if: osx
      then: llvm-openmp
    - if: linux
      then: libgomp
  host:
    - python
    - pip
    - setuptools
    - libnetcdf
    - numpy
    - scipy
    - if: osx
      then: llvm-openmp
    - if: linux
      then: libgomp
  run:
    - python
    - numpy
    - scipy

