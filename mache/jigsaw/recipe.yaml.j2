about:
  summary: |
    jigsawpy is the python interface to JIGSAW, which is a Delaunay-based
    unstructured mesh generator for two- and three-dimensional geometries.
  license: LicenseRef-custom
  license_file:
    - LICENSE.md
  homepage: https://github.com/dengwirda/jigsaw-python
  documentation: https://github.com/dengwirda/jigsaw-python

